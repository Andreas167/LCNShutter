{
    "elements": [
        {
            "type": "Label",
            "bold": true,
            "caption": "LCN Relais-Konfiguration (Fahren + Richtung)"
        },
        {
            "type": "Label",
            "caption": "Klassische LCN-Schaltung: ein Relais für Motor AN/AUS, ein Relais für Richtung AUF/AB."
        },
        {
            "type": "SelectVariable",
            "name": "RelayRunID",
            "caption": "Relais FAHREN  (Boolean-Variable, ON = Motor läuft)",
            "width": "400px"
        },
        {
            "type": "SelectVariable",
            "name": "RelayDirectionID",
            "caption": "Relais RICHTUNG (Boolean-Variable, OFF = AUF / ON = AB)",
            "width": "400px"
        },
        {
            "type": "Label",
            "caption": " "
        },
        {
            "type": "Label",
            "bold": true,
            "caption": "Fahrzeiten (Einmessung)"
        },
        {
            "type": "NumberSpinner",
            "name": "TravelTimeUp",
            "caption": "Fahrtzeit AUF  (Sekunden)",
            "digits": 1,
            "minimum": 1,
            "maximum": 300,
            "suffix": " s"
        },
        {
            "type": "NumberSpinner",
            "name": "TravelTimeDown",
            "caption": "Fahrtzeit AB   (Sekunden)",
            "digits": 1,
            "minimum": 1,
            "maximum": 300,
            "suffix": " s"
        },
        {
            "type": "Label",
            "caption": " "
        },
        {
            "type": "Label",
            "bold": true,
            "caption": "Erweiterte Einstellungen"
        },
        {
            "type": "NumberSpinner",
            "name": "SafetyDelayMS",
            "caption": "Sicherheitspause vor Richtungswechsel",
            "minimum": 50,
            "maximum": 1000,
            "suffix": " ms"
        },
        {
            "type": "CheckBox",
            "name": "InvertDirection",
            "caption": "Fahrtrichtung umkehren (Richtungsrelais vertauscht verdrahtet)"
        }
    ],

    "actions": [
        {
            "type": "Label",
            "bold": true,
            "caption": "Testfunktionen"
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "Button",
                    "caption": "▲  AUF fahren",
                    "onClick": "LRS_MoveUp($id);"
                },
                {
                    "type": "Button",
                    "caption": "■  STOPP",
                    "onClick": "LRS_Stop($id);"
                },
                {
                    "type": "Button",
                    "caption": "▼  AB fahren",
                    "onClick": "LRS_MoveDown($id);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": " "
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "TestPosition",
                    "caption": "Zielposition",
                    "minimum": 0,
                    "maximum": 100,
                    "suffix": " %"
                },
                {
                    "type": "Button",
                    "caption": "Anfahren",
                    "onClick": "LRS_MoveTo($id, $TestPosition);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": " "
        },
        {
            "type": "Label",
            "bold": true,
            "caption": "Kalibrierung"
        },
        {
            "type": "Label",
            "caption": "Fährt auf untere Endlage (+ 20 % Puffer) und setzt Position = 100 %."
        },
        {
            "type": "Button",
            "caption": "Kalibrierung starten",
            "onClick": "LRS_Calibrate($id);"
        }
    ],

    "status": [
        { "code": 102, "icon": "active",   "caption": "Aktiv" },
        { "code": 104, "icon": "inactive", "caption": "Konfiguration unvollständig – bitte Relais-Variablen wählen" },
        { "code": 200, "icon": "error",    "caption": "Fehler: Fahren und Richtung sind identisch" },
        { "code": 201, "icon": "error",    "caption": "Fehler: Relais-Variable nicht gefunden" }
    ]
}
