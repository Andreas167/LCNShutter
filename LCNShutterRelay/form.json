{
    "elements": [
        {
            "type": "Label",
            "bold": true,
            "caption": "LCN Schaltinstanzen (Fahren + Richtung)"
        },
        {
            "type": "Label",
            "caption": "Wähle für jedes Relais die zugehörige Symcon-Schaltinstanz (z.B. LCN Relais). Das Modul steuert die Instanz über deren Status-Variable."
        },
        {
            "type": "SelectInstance",
            "name": "RelayRunInstanceID",
            "caption": "Schaltinstanz  FAHREN   (Status=ON → Motor läuft)"
        },
        {
            "type": "SelectInstance",
            "name": "RelayDirectionInstanceID",
            "caption": "Schaltinstanz  RICHTUNG  (Status=OFF → AUF  /  Status=ON → AB)"
        },
        {
            "type": "Label",
            "caption": " "
        },
        {
            "type": "Label",
            "bold": true,
            "caption": "Fahrzeiten (Einmessung)"
        },
        {
            "type": "NumberSpinner",
            "name": "TravelTimeUp",
            "caption": "Fahrtzeit AUF  (Sekunden)",
            "digits": 1,
            "minimum": 1,
            "maximum": 300,
            "suffix": " s"
        },
        {
            "type": "NumberSpinner",
            "name": "TravelTimeDown",
            "caption": "Fahrtzeit AB   (Sekunden)",
            "digits": 1,
            "minimum": 1,
            "maximum": 300,
            "suffix": " s"
        },
        {
            "type": "Label",
            "caption": " "
        },
        {
            "type": "Label",
            "bold": true,
            "caption": "Erweiterte Einstellungen"
        },
        {
            "type": "NumberSpinner",
            "name": "SafetyDelayMS",
            "caption": "Sicherheitspause vor Richtungswechsel",
            "minimum": 50,
            "maximum": 1000,
            "suffix": " ms"
        },
        {
            "type": "CheckBox",
            "name": "InvertDirection",
            "caption": "Fahrtrichtung umkehren (Richtungsrelais vertauscht verdrahtet)"
        }
    ],

    "actions": [
        {
            "type": "Label",
            "bold": true,
            "caption": "Testfunktionen"
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "Button",
                    "caption": "▲  AUF",
                    "onClick": "LRS_MoveUp($id);"
                },
                {
                    "type": "Button",
                    "caption": "■  STOPP",
                    "onClick": "LRS_Stop($id);"
                },
                {
                    "type": "Button",
                    "caption": "▼  AB",
                    "onClick": "LRS_MoveDown($id);"
                }
            ]
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "TestPosition",
                    "caption": "Zielposition",
                    "minimum": 0,
                    "maximum": 100,
                    "suffix": " %"
                },
                {
                    "type": "Button",
                    "caption": "Anfahren",
                    "onClick": "LRS_MoveTo($id, $TestPosition);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": " "
        },
        {
            "type": "Button",
            "caption": "Kalibrierung starten (fährt auf untere Endlage)",
            "onClick": "LRS_Calibrate($id);"
        }
    ],

    "status": [
        { "code": 102, "icon": "active",   "caption": "Aktiv" },
        { "code": 104, "icon": "inactive", "caption": "Bitte Schaltinstanzen auswählen" },
        { "code": 200, "icon": "error",    "caption": "Fehler: FAHREN und RICHTUNG sind dieselbe Instanz" },
        { "code": 201, "icon": "error",    "caption": "Fehler: Status-Variable der Instanz nicht gefunden" }
    ]
}
